{
  "_comment": "Copied to wisp-config.json on first install. Lives in config/; kept chmod 600 because it may hold SMB passwords and the OIDC client secret (Settings writes it 0600).",
  "serverName": "My Server",
  "vmsPath": "/var/lib/wisp/vms",
  "imagePath": "/var/lib/wisp/images",
  "containersPath": "/var/lib/wisp/containers",
  "backupLocalPath": "/var/lib/wisp/backups",
  "mounts": [],
  "backupMountId": null,
  "discoveryEnabled": true,
  "advertisedUrl": null,
  "oidc": { "enabled": false, "issuer": "", "clientId": "", "clientSecret": "" },
  "trustedProxies": []
}
