# Optional. If missing, Wisp uses built-in defaults (backend 3001, frontend 8080).
# Copy to runtime.env and edit if you need non-default ports or bridge override.

# WISP_BACKEND_PORT=3001
# WISP_FRONTEND_PORT=8080

# Optional: default bridge for new VM NICs (auto-detected if unset)
# WISP_DEFAULT_BRIDGE=br0

# Optional: GitHub API token for some download flows (dev/advanced)
# GITHUB_TOKEN=

# Optional: override path to wisp-smartctl (defaults: /usr/local/bin, then backend/scripts/)
# WISP_SMARTCTL_SCRIPT=
