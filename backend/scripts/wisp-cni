#!/usr/bin/env bash
# Run one CNI plugin with config on stdin (from a temp file). Invoked via sudo -n.
# Usage: wisp-cni <ADD|DEL> <plugin_basename> <container_id> <netns_path> <config_json_file> [cni_bin_dir]
# 6th arg is the plugin directory (passed from the backend; sudo resets env so we do not rely on CNI_PATH).
set -euo pipefail

CMD="${1:?command}"
PLUGIN_NAME="${2:?plugin}"
CID="${3:?container_id}"
NETNS="${4:?netns}"
CONF="${5:?config_file}"
CNI_PATH="${6:-/opt/cni/bin}"

[[ "$CID" =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]{0,62}$ ]] || { echo "wisp-cni: invalid container id" >&2; exit 1; }
# Plugin name is a bare CNI plugin type (e.g. bridge, dhcp). Reject any path
# separator or traversal so "$CNI_PATH/$PLUGIN_NAME" can't escape the bin dir.
[[ "$PLUGIN_NAME" =~ ^[a-z0-9-]+$ ]] || { echo "wisp-cni: invalid plugin name" >&2; exit 1; }
[[ "$CNI_PATH" =~ ^/ ]] || { echo "wisp-cni: cni bin dir must be absolute path" >&2; exit 1; }
[[ "$NETNS" =~ ^/ ]] || { echo "wisp-cni: netns must be absolute path" >&2; exit 1; }
[[ -f "$CONF" ]] || { echo "wisp-cni: missing config file" >&2; exit 1; }
# Resolve the bin dir and confine the plugin under it — belt-and-suspenders on
# top of the plugin-name charset check, matching the confinement wisp-mount /
# wisp-nvram do for their path arguments.
BIN_ROOT="$(realpath -e "$CNI_PATH" 2>/dev/null)" || { echo "wisp-cni: cni bin dir not found: $CNI_PATH" >&2; exit 1; }
PLUGIN="$(realpath -e "$BIN_ROOT/$PLUGIN_NAME" 2>/dev/null)" || { echo "wisp-cni: plugin not found: $CNI_PATH/$PLUGIN_NAME" >&2; exit 1; }
case "$PLUGIN" in
  "$BIN_ROOT"/*) : ;;
  *) echo "wisp-cni: plugin escapes cni bin dir: $PLUGIN" >&2; exit 1 ;;
esac
[[ -f "$PLUGIN" && -x "$PLUGIN" ]] || { echo "wisp-cni: plugin not executable: $PLUGIN" >&2; exit 1; }

export CNI_COMMAND="$CMD"
export CNI_CONTAINERID="$CID"
export CNI_NETNS="$NETNS"
export CNI_IFNAME=eth0
export CNI_PATH

"$PLUGIN" < "$CONF"
