#!/usr/bin/env bash
# Usage: wisp-smb mount <configPath> | check <configPath> | unmount <mountPath>
#   mount   - reads config (share=, mountPath=, username=, password=), creates mount point, runs mount.cifs, then removes config file.
#   check   - same as mount but then unmounts and removes the mount point (tests connection only).
#   unmount - runs umount on the given path.
# Must be run with sufficient privilege (root or sudo). Install cifs-utils. Sudoers: NOPASSWD for this script.
set -euo pipefail

CMD="${1:-}"
ARG="${2:-}"

do_mount() {
  # shellcheck source=/dev/null
  source "$1"
  if [[ -z "${mountPath:-}" || -z "${share:-}" ]]; then
    echo "Config must set mountPath and share" >&2
    exit 1
  fi
  mkdir -p "$mountPath"
  opts="rw"
  if [[ -n "${uid:-}" ]]; then
    opts="${opts},uid=${uid}"
  fi
  if [[ -n "${gid:-}" ]]; then
    opts="${opts},gid=${gid}"
  fi
  if [[ -n "${username:-}" ]]; then
    opts="${opts},username=${username}"
  fi
  if [[ -n "${password:-}" ]]; then
    opts="${opts},password=${password}"
  fi
  opts="${opts#,}"
  if [[ -n "$opts" ]]; then
    mount -t cifs "$share" "$mountPath" -o "$opts"
  else
    mount -t cifs "$share" "$mountPath"
  fi
}

do_check() {
  do_mount "$1"
  umount "$mountPath"
  rmdir "$mountPath"
  rm -f "$1"
}

case "$CMD" in
  mount)
    if [[ -z "$ARG" || ! -f "$ARG" ]]; then
      echo "Usage: $0 mount <configPath>" >&2
      exit 1
    fi
    do_mount "$ARG"
    rm -f "$ARG"
    ;;
  check)
    if [[ -z "$ARG" || ! -f "$ARG" ]]; then
      echo "Usage: $0 check <configPath>" >&2
      exit 1
    fi
    do_check "$ARG"
    rm -f "$ARG"
    ;;
  unmount)
    if [[ -z "$ARG" || ! "$ARG" =~ ^/ ]]; then
      echo "Usage: $0 unmount <mountPath>" >&2
      exit 1
    fi
    umount "$ARG"
    ;;
  *)
    echo "Usage: $0 mount <configPath> | check <configPath> | unmount <mountPath>" >&2
    exit 1
    ;;
esac
