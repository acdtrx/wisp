#!/usr/bin/env bash
# Usage:
#   wisp-mount smb mount    <configPath>
#   wisp-mount smb check    <configPath>
#   wisp-mount disk mount   <configPath>
#   wisp-mount unmount      <mountPath>
#   wisp-mount unmount-lazy <mountPath>
#   wisp-mount rmdir        <mountPath under /mnt/wisp/>   # delete-only cleanup; no-op if non-empty or missing
#
# Config file format (one key=value per line; '#' comments and blank lines ignored):
#   SMB:  share, mountPath, credentialsPath, uid, gid
#   Disk: uuid, mountPath, fsType, readOnly (0|1), uid, gid
#
# The SMB `credentialsPath` points at a separate mode-0600 file in the standard
# mount.cifs format (`username=...` / `password=...` / `domain=...`), passed to
# the kernel via `mount -o credentials=<path>` so secrets never appear on argv
# (`/proc/<pid>/cmdline`) or in this script's environment. The JS caller
# (smbMount.js) writes both files in a temp dir and unlinks them after the
# helper returns.
#
# Parsing the config file uses a strict allow-listed key=value parser — never
# `source`. Any unknown key, multi-line value, or value containing a literal
# newline is rejected. This stops a JS-side regression from turning the helper
# into a `bash -e` primitive.
#
# Install: sudoers NOPASSWD for this script (installed by scripts/linux/setup/install-helpers.sh).
set -euo pipefail

CMD="${1:-}"
SUB="${2:-}"
ARG="${3:-}"

SUPPORTED_DISK_FSTYPES=(ext4 btrfs vfat exfat ntfs3)
WISP_MOUNT_ROOT="/mnt/wisp"

is_supported_fstype() {
  local t="$1"
  for x in "${SUPPORTED_DISK_FSTYPES[@]}"; do
    [[ "$x" == "$t" ]] && return 0
  done
  return 1
}

# Defense in depth: refuse to mount over anything outside /mnt/wisp/. The JS
# caller already validates this; if it ever regresses, this block stops the
# helper from shadowing /etc, /usr, /home, etc.
assert_mount_path_under_wisp() {
  local p="$1"
  if [[ -z "$p" || "${p:0:1}" != "/" ]]; then
    echo "mountPath must be an absolute path" >&2
    exit 64
  fi
  local resolved
  resolved="$(realpath -m -- "$p")"
  case "$resolved" in
    "${WISP_MOUNT_ROOT}/"*) : ;;
    *)
      echo "mountPath must be under ${WISP_MOUNT_ROOT}/ (got ${resolved})" >&2
      exit 64
      ;;
  esac
}

# Strict key=value parser. Reads a config file line by line, splits on the
# first '=', and only assigns to known keys. Rejects unknown keys with exit 64.
# Variables are written via `printf -v` so values stay literal (no $-expansion,
# no command substitution, no glob expansion).
read_smb_config() {
  share=""
  mountPath=""
  credentialsPath=""
  uid=""
  gid=""
  local line k v
  while IFS= read -r line || [[ -n "$line" ]]; do
    case "$line" in
      \#*|'') continue ;;
      *=*)
        k="${line%%=*}"
        v="${line#*=}"
        case "$k" in
          share|mountPath|credentialsPath|uid|gid)
            printf -v "$k" '%s' "$v"
            ;;
          *)
            echo "wisp-mount: unknown config key: $k" >&2
            exit 64
            ;;
        esac
        ;;
      *)
        echo "wisp-mount: malformed config line" >&2
        exit 64
        ;;
    esac
  done < "$1"
}

read_disk_config() {
  uuid=""
  mountPath=""
  fsType=""
  readOnly=""
  uid=""
  gid=""
  local line k v
  while IFS= read -r line || [[ -n "$line" ]]; do
    case "$line" in
      \#*|'') continue ;;
      *=*)
        k="${line%%=*}"
        v="${line#*=}"
        case "$k" in
          uuid|mountPath|fsType|readOnly|uid|gid)
            printf -v "$k" '%s' "$v"
            ;;
          *)
            echo "wisp-mount: unknown config key: $k" >&2
            exit 64
            ;;
        esac
        ;;
      *)
        echo "wisp-mount: malformed config line" >&2
        exit 64
        ;;
    esac
  done < "$1"
}

do_smb_mount() {
  read_smb_config "$1"
  if [[ -z "${mountPath:-}" || -z "${share:-}" ]]; then
    echo "Config must set mountPath and share" >&2
    exit 1
  fi
  if [[ -z "${credentialsPath:-}" || ! -f "$credentialsPath" ]]; then
    echo "Config must set credentialsPath pointing to a readable file" >&2
    exit 1
  fi
  assert_mount_path_under_wisp "$mountPath"
  mkdir -p "$mountPath"
  local opts="rw,credentials=${credentialsPath}"
  [[ -n "${uid:-}" ]] && opts="${opts},uid=${uid}"
  [[ -n "${gid:-}" ]] && opts="${opts},gid=${gid}"
  mount -t cifs "$share" "$mountPath" -o "$opts"
}

do_smb_check() {
  do_smb_mount "$1"
  umount "$mountPath"
  rmdir "$mountPath"
}

do_disk_mount() {
  read_disk_config "$1"
  if [[ -z "${mountPath:-}" || -z "${uuid:-}" || -z "${fsType:-}" ]]; then
    echo "Config must set mountPath, uuid, and fsType" >&2
    exit 1
  fi
  assert_mount_path_under_wisp "$mountPath"
  if ! is_supported_fstype "$fsType"; then
    echo "Unsupported fsType: $fsType" >&2
    exit 1
  fi
  local devPath="/dev/disk/by-uuid/$uuid"
  if [[ ! -e "$devPath" ]]; then
    echo "Device not present: $devPath" >&2
    exit 1
  fi
  mkdir -p "$mountPath"
  local opts=""
  local ro=""
  [[ "${readOnly:-0}" == "1" ]] && ro="ro"
  # ntfs3 forced to ro by the backend; enforce here too.
  [[ "$fsType" == "ntfs3" ]] && ro="ro"

  case "$fsType" in
    vfat|exfat|ntfs3)
      opts=""
      [[ -n "$ro" ]] && opts="${opts},${ro}"
      [[ -n "${uid:-}" ]] && opts="${opts},uid=${uid}"
      [[ -n "${gid:-}" ]] && opts="${opts},gid=${gid}"
      opts="${opts},umask=0007"
      ;;
    ext4|btrfs)
      opts="defaults"
      [[ -n "$ro" ]] && opts="${opts},${ro}"
      ;;
  esac
  opts="${opts#,}"
  mount -t "$fsType" "$devPath" "$mountPath" -o "$opts"
}

case "$CMD" in
  smb)
    if [[ -z "$ARG" || ! -f "$ARG" ]]; then
      echo "Usage: $0 smb mount|check <configPath>" >&2
      exit 1
    fi
    case "$SUB" in
      mount) do_smb_mount "$ARG"; rm -f "$ARG" ;;
      check) do_smb_check "$ARG"; rm -f "$ARG" ;;
      *) echo "Usage: $0 smb mount|check <configPath>" >&2; exit 1 ;;
    esac
    ;;
  disk)
    if [[ "$SUB" != "mount" ]]; then
      echo "Usage: $0 disk mount <configPath>" >&2
      exit 1
    fi
    if [[ -z "$ARG" || ! -f "$ARG" ]]; then
      echo "Usage: $0 disk mount <configPath>" >&2
      exit 1
    fi
    do_disk_mount "$ARG"
    rm -f "$ARG"
    ;;
  unmount)
    PATH_ARG="$SUB"
    if [[ -z "$PATH_ARG" || "${PATH_ARG:0:1}" != "/" ]]; then
      echo "Usage: $0 unmount <mountPath>" >&2
      exit 1
    fi
    umount "$PATH_ARG"
    ;;
  unmount-lazy)
    PATH_ARG="$SUB"
    if [[ -z "$PATH_ARG" || "${PATH_ARG:0:1}" != "/" ]]; then
      echo "Usage: $0 unmount-lazy <mountPath>" >&2
      exit 1
    fi
    umount -l "$PATH_ARG"
    ;;
  rmdir)
    PATH_ARG="$SUB"
    # rmdir is scoped to /mnt/wisp/* as a safety net — used only by the delete flow.
    if [[ -z "$PATH_ARG" || "$PATH_ARG" != /mnt/wisp/* ]]; then
      echo "Usage: $0 rmdir <mountPath under /mnt/wisp/>" >&2
      exit 1
    fi
    rmdir "$PATH_ARG" 2>/dev/null || true
    ;;
  *)
    echo "Usage: $0 smb mount|check <configPath> | disk mount <configPath> | unmount <mountPath> | unmount-lazy <mountPath>" >&2
    exit 1
    ;;
esac
